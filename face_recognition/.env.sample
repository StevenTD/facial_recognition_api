# =============================================================================
# Django Core
# =============================================================================
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=*
CORS_ALLOW_ALL_ORIGINS=True

# =============================================================================
# Database  (SQLite is the default; override for PostgreSQL/MySQL)
# =============================================================================
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3
# DB_USER=
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=

# =============================================================================
# Internationalization
# =============================================================================
LANGUAGE_CODE=en-us
TIME_ZONE=Asia/Manila

# =============================================================================
# Anti-Spoofing / Liveness Detection
# =============================================================================
LIVENESS_DETECTION_ENABLED=False

# =============================================================================
# Face Recognition
# =============================================================================
FACE_RECOGNITION_OPTIMIZED=False
FACE_RECOGNITION_TOLERANCE=0.45
FACE_STRICT_DUPLICATE_CHECK=False

# =============================================================================
# Frappe HRMS Integration
# =============================================================================
FRAPPE_BASE_URL=http://your-frappe-host:8000
FRAPPE_API_KEY=your-api-key
FRAPPE_API_SECRET=your-api-secret
FRAPPE_EMPLOYEE_FIELDNAME=name
FRAPPE_DEVICE_ID=FACIAL_RECOGNITION_KIOSK_01
FRAPPE_TIMEOUT=10
